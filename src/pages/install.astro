---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Instalează | cuza.pages.dev" nofollow noindex>
  <div class="flex items-center justify-center h-svh px-5 py-8">
    <div
      class="bg-[rgba(10,13,16,.85)] text-white rounded-3xl p-8 md:p-10 shadow-2xl backdrop-blur-sm border border-white/10 max-w-sm w-full text-center relative overflow-hidden"
    >
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-24 bg-blue-500/20 blur-[50px] rounded-full pointer-events-none"
      >
      </div>

      <div class="relative flex justify-center mb-5">
        <div
          class="w-20 h-20 rounded-2xl bg-white/10 p-3 shadow-lg ring-1 ring-white/10 flex items-center justify-center"
        >
          <img
            src="/assets/img/logo/atoms_192px.png"
            alt="CuzaPages"
            class="w-full h-full rounded-xl"
            width="56"
            height="56"
          />
        </div>
      </div>

      <h1 class="text-2xl font-bold mb-1 text-white">CuzaPages</h1>

      <p class="text-sm text-gray-400 mb-6">Subiecte de bac și admitere</p>

      <ul
        class="text-left text-sm text-gray-300 mb-7 space-y-3 mx-auto max-w-60"
      >
        <li class="flex items-start gap-3">
          <svg
            class="w-5 h-5 text-blue-400 mt-0.5 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
          <span>Acces rapid din ecranul principal</span>
        </li>
        <li class="flex items-start gap-3">
          <svg
            class="w-5 h-5 text-blue-400 mt-0.5 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
          <span>Funcționează și fără conexiune</span>
        </li>
        <li class="flex items-start gap-3">
          <svg
            class="w-5 h-5 text-blue-400 mt-0.5 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
          </svg>
          <span>Experiență full-screen, fără bara de navigare</span>
        </li>
      </ul>

      <button
        id="installBtn"
        class="w-full bg-blue-600 hover:bg-blue-500 disabled:bg-gray-700 disabled:text-gray-400 text-white font-semibold py-3.5 px-6 rounded-xl transition-colors cursor-pointer disabled:cursor-not-allowed text-base"
        onclick="install()"
        disabled="disabled"
      >
        <span id="installBtnText">Instalează aplicația</span>
      </button>

      <p
        id="iosInstructions"
        class="mt-5 text-sm text-gray-500 leading-relaxed"
        style="display: none;"
      >
        Deschide meniul
        <span class="text-white font-medium"> Share </span>
        în Safari și apasă<br />
        <span class="text-white font-medium">
          Adaugă la ecranul principal
        </span>.
      </p>

      <div
        id="desktopInstructions"
        class="mt-5 text-sm text-gray-500"
        style="display: none;"
      >
        <p class="mb-5">
          Scanează codul QR de pe telefon pentru a instala aplicația:
        </p>
        <img
          src="/assets/img/QR-code.png"
          alt="QR Code pentru CuzaPages"
          class="mx-auto w-36 h-36 rounded-xl"
          width="144"
          height="144"
          loading="lazy"
        />
      </div>
    </div>
  </div>
<script is:inline>
    var beforeInstallPrompt = null;
    var installBtn = document.getElementById('installBtn');
    var installBtnText = document.getElementById('installBtnText');
    var iosEl = document.getElementById('iosInstructions');
    var desktopEl = document.getElementById('desktopInstructions');
    var isStandalone =
      window.matchMedia('(display-mode: standalone)').matches ||
      navigator.standalone;
    var isIOS =
      /iPad|iPhone|iPod/.test(navigator.userAgent) ||
      (navigator.maxTouchPoints > 1 && /Mac/.test(navigator.userAgent));
    var isMobile = /Mobi|Android/.test(navigator.userAgent);

    window.addEventListener('beforeinstallprompt', function (event) {
      beforeInstallPrompt = event;
      installBtn.removeAttribute('disabled');
    });

    if (isStandalone) {
      installBtnText.textContent = 'Aplicația este deja instalată';
      installBtn.classList.remove('bg-blue-600', 'hover:bg-blue-500');
      installBtn.classList.add('bg-gray-700', 'text-gray-400');
      installBtn.disabled = true;
    }

    if (isIOS) {
      installBtn.style.display = 'none';
      if (iosEl) iosEl.style.display = 'block';
    }

    if (!isMobile) {
      installBtn.style.display = 'none';
      if (desktopEl) desktopEl.style.display = 'block';
    }

    function install() {
      if (beforeInstallPrompt) beforeInstallPrompt.prompt();
    }
  </script>
</Layout>
