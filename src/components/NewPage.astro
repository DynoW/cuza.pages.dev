---
import Layout from '../layouts/Layout.astro';
import ContentContainer from '../layouts/ContentContainer.astro';
import NewNavbar from '../components/NewNavbar.astro';
import List from './List.astro';
import Extra from '../components/Extra.astro';
import Footer from '../components/Footer.astro';
import CountdownTimer from './CountdownTimer.astro';
import SiteLinks from './SiteLinks.astro';
import { apiService } from '../api';
import { getDisplayName, PAGE_DISPLAY_NAMES } from '../config/labels';
import type { FileStructure } from '../types';

// Props for the component
interface Props {
  subject: string;
  page: string;
}

const { subject, page } = Astro.props as Props;

// Single request for all page data
const pageData = await apiService.getPageData(subject, page);
const content: FileStructure = pageData.content;
const years: number[] = pageData.years;
const extra: FileStructure = pageData.extra;

// ── SEO helpers ──────────────────────────────────────────────────────────────
const subjectLabel =
  subject === 'admitere' ? 'Admitere UPB' : getDisplayName(subject);
const pageLabel = PAGE_DISPLAY_NAMES[page] ?? getDisplayName(page);
const isHome = subject === 'fizica' && page === 'bac';

const pageTitle = isHome
  ? 'Mate-Fizică BAC | cuza.pages.dev'
  : `${subjectLabel} - ${pageLabel} | cuza.pages.dev`;
const pageDescription = `Subiecte oficiale, variante și simulări ${pageLabel} la ${subjectLabel}. Descarcă gratuit PDF-uri pentru pregătire BAC și admitere. Liceul Teoretic Alexandru Ioan Cuza, București.`;
const pageKeywords = `${subjectLabel.toLowerCase()}, ${pageLabel.toLowerCase()}, bacalaureat, subiecte, variante, bareme, simulare, cuza, LTAIC, UPB`;

const subjectBaseUrl =
  subject === 'fizica'
    ? 'https://cuza.pages.dev'
    : `https://cuza.pages.dev/${subject}`;
const canonicalUrl =
  page === 'bac' ? subjectBaseUrl : `https://cuza.pages.dev/${subject}/${page}`;

const breadcrumbs = [
  { name: subjectLabel, url: subjectBaseUrl },
  ...(page !== 'bac' ? [{ name: pageLabel, url: canonicalUrl }] : []),
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  canonicalUrl={canonicalUrl}
  breadcrumbs={breadcrumbs}
>
  <ContentContainer>
    <aside slot="left" class="flex flex-col gap-2 lg:ml-2 lg:mt-2">
      <NewNavbar />
      <SiteLinks wrapperClass="hidden lg:flex" />
    </aside>
    <div slot="middle" class="flex flex-col gap-2">
      <div class="bg-gray-100/90 rounded-3xl p-5 pr-2.5 font-bold">
        <List subject={subject} page={page} content={content} />
      </div>
    </div>
    <aside
      slot="right"
      class="flex flex-col gap-2 md:mt-2 md:mr-2 md:sticky md:top-2 md:right-2"
    >
      <div class="bg-zinc-950/90 rounded-3xl py-3 px-4">
        <Extra subject={subject} page={page} extraData={extra} years={years} />
      </div>
      <CountdownTimer />
    </aside>
  </ContentContainer>
  <Footer />
</Layout>
